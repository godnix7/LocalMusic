generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ARTIST
  ADMIN
}

enum BillingTier {
  FREE
  PATRON
}

enum AlbumType {
  ALBUM
  SINGLE
  EP
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  passwordHash    String
  username        String      @unique
  role            Role        @default(USER)
  billingTier     BillingTier @default(FREE)
  isApproved      Boolean     @default(false)
  registrationRegion String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  profile         Profile?
  artistProfile   ArtistProfile?
  sessions        Session[]
  playlists       Playlist[]
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  handle        String   @unique
  displayName   String?
  avatarUrl     String?
  bio           String?
  settings      Json?    // Audio quality, notifications, etc.
  tasteProfile  Json?    // genres, energy, etc.
  socialLinks   Json?    // spotify, instagram links
}

model ArtistProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  bio             String?
  image           String?
  coverImage      String?
  monthlyListeners Int     @default(0)
  isVerified      Boolean  @default(false)
  socialLinks     Json?
  monetization    Json?    // Tip jar url, merch links

  tracks          Track[]
  albums          Album[]
}

model Track {
  id              String   @id @default(uuid())
  title           String
  duration        Int      // in seconds
  isExplicit      Boolean  @default(false)
  audioUrl        String
  coverUrl        String?
  spotifyId       String?  @unique
  highQualityUrl  String?
  losslessUrl     String?
  playCount       Int      @default(0)
  lyricsId        String?
  bpm             Int?
  key             String?
  releaseDate     DateTime @default(now())
  
  artistId        String
  artist          ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  albumId         String?
  album           Album?   @relation(fields: [albumId], references: [id], onDelete: Cascade)

  storage         SongStorage?
}

model Album {
  id          String   @id @default(uuid())
  title       String
  coverArt    String?
  releaseDate DateTime @default(now())
  type        AlbumType @default(ALBUM)
  
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks      Track[]
}

model Playlist {
  id          String   @id @default(uuid())
  name        String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs       String[] // Array of track IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SongStorage {
  id          String   @id @default(uuid())
  trackId     String   @unique
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  filePath    String
  storageType String   @default("LOCAL") // LOCAL | S3
  createdAt   DateTime @default(now())
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  deviceId  String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model IngestionTask {
  id              String   @id @default(uuid())
  url             String
  status          String   // PENDING, RUNNING, COMPLETED, FAILED, STOPPED
  progress        Int      @default(0)
  totalTracks     Int      @default(0)
  completedTracks Int      @default(0)
  pid             Int?     // Process ID to allow stopping
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
