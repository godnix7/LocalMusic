{
  "name": "@local-music/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs,esm --clean --dts",
    "start": "node dist/server.js",
    "seed": "tsx src/db/prisma/seed.ts",
    "prisma:generate": "prisma generate --schema src/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/db/prisma/schema.prisma",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.11.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^5.5.2",
    "@types/multer": "^2.1.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "music-metadata": "^11.12.3",
    "p-limit": "^3.1.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.3",
    "prisma": "^5.5.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.8.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.19.1",
    "@typescript-eslint/eslint-plugin": "^6.19.1"
  }
}
